<odoo>

    <record id="view_plaid_transactions_sync_wizard_form" model="ir.ui.view">
        <field name="name">Plaid Transactions</field>
        <field name="model">plaid.transaction.wizard</field>
        <field name="arch" type="xml">
            <form>
                <group>
                    <group >
                        <field name="bank_id" options="{'no_create': True}" />
                        <field name="account_ids" widget="many2many_tags" domain="[('bank_id', '=', bank_id)]" options="{'no_create': True}"/>
                    </group>
                    <group >
                        <field name="from_date" />
                        <field name="to_date" />
                    </group>
                </group>
                <footer>
                    <button string="Fetch Transactions" name="fetch_transactions" type="object" class="oe_highlight" data-hotkey="q"/>
                    <button string="Cancel" class="btn btn-secondary" special="cancel" data-hotkey="z"/>
                </footer>
            </form>

        </field>
    </record>

</odoo>